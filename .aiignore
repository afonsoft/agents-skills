# .aiignore

# Generated files and build artifacts
*.backup.*
*.tmp
*.log
.DS_Store
Thumbs.db

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build outputs
dist/
build/
out/
bin/
obj/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Configuration files with sensitive data
.env
.env.local
.env.*.local
config/secrets.json
**/secrets/
**/private/

# Large binaries and media
*.exe
*.dmg
*.pkg
*.deb
*.rpm
*.zip
*.tar.gz
*.rar
*.7z

# Database files
*.db
*.sqlite
*.sqlite3

# Cache directories
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Test coverage
coverage/
*.lcov

# Documentation build
docs/_build/
site/

# Temporary files
tmp/
temp/
.tmp/

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backup files created by install scripts
*.backup.*
.backup/
