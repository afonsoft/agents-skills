#!/usr/bin/env bash
# SessionStart hook for Google Antigravity IDE
# Injects skills catalog context at session start.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/session-start-base.sh"

# Antigravity IDE: additionalContext (SDK standard)
printf '{\n  "additionalContext": "%s"\n}\n' "$SESSION_CONTEXT"
exit 0
