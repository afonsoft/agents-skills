#!/usr/bin/env bash
# SessionStart hook for Gemini CLI
# Injects Itau skills catalog context at session start.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/session-start-base.sh"

# Gemini CLI: additionalContext (SDK standard)
printf '{\n  "additionalContext": "%s"\n}\n' "$SESSION_CONTEXT"
exit 0
