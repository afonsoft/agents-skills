#!/usr/bin/env bash
# SessionStart hook for Cursor
# Injects Itau skills catalog context at session start.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/session-start-base.sh"

# Cursor: additional_context (snake_case, top-level)
printf '{\n  "additional_context": "%s"\n}\n' "$SESSION_CONTEXT"
exit 0
