#!/usr/bin/env bash
# SessionStart hook for VS Code / GitHub Copilot
# Injects the skills catalog context at session start.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/session-start-base.sh"

# Copilot CLI (SDK standard): additionalContext (top-level)
printf '{\n  "additionalContext": "%s"\n}\n' "$SESSION_CONTEXT"
exit 0
