#!/usr/bin/env bash
# SessionStart hook for Windsurf (Cascade)
# Injects Itau skills catalog context at session start.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/session-start-base.sh"

# Windsurf: same format as Cursor (additional_context)
printf '{\n  "additional_context": "%s"\n}\n' "$SESSION_CONTEXT"
exit 0
